{
  "manifest_version": 3,
  "name": "WolfGrid REALTOR.ca Scraper",
  "version": "0.1.1",
  "description": "Capture REALTOR.ca agent leads from your normal Chrome session and send them to WolfGrid.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.realtor.ca/*",
    "https://realtor.ca/*",
    "https://wolfgrid.app/*",
    "https://*.wolfgrid.app/*",
    "https://flyrpro.app/*",
    "https://*.flyrpro.app/*",
    "https://flyr.software/*",
    "https://*.flyr.software/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scrape REALTOR.ca",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.realtor.ca/*", "https://realtor.ca/*"],
      "js": ["content-realtor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://wolfgrid.app/*",
        "https://*.wolfgrid.app/*",
        "https://flyrpro.app/*",
        "https://*.flyrpro.app/*",
        "https://flyr.software/*",
        "https://*.flyr.software/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content-wolfgrid.js"],
      "run_at": "document_idle"
    }
  ]
}
