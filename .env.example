# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Standard Canvassing Mode web map fallback (Google Maps)
NEXT_PUBLIC_GOOGLE_MAPS_STANDARD_MODE_API_KEY=

# Twilio Voice dialer
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_FROM_NUMBER=
# Optional fallback for post-call SMS follow-up
TWILIO_DEFAULT_SMS_FROM_NUMBER=
# Optional inbound call forwarding target for your Twilio number
TWILIO_INBOUND_FORWARD_TO=
# Optional spoken fallback when inbound forwarding is not configured
TWILIO_INBOUND_FALLBACK_MESSAGE=
# Optional prerecorded voicemail drop audio file URL (mp3/wav)
TWILIO_VOICEMAIL_DROP_AUDIO_URL=
# Optional spoken fallback when voicemail drop audio is not configured
TWILIO_VOICEMAIL_DROP_MESSAGE=
# Optional comma-separated allowlist for dialer testing by workspace ID
DIALER_ENABLED_WORKSPACE_IDS=

# Stripe billing
# Coupon used to auto-create ambassador promotion codes
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID=
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID_TEST=
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID_LIVE=
# Legacy fallback if you only use one dialer price
STRIPE_PRICE_DIALER_MONTHLY=
# Recommended regional dialer prices
STRIPE_PRICE_DIALER_CAD_MONTHLY=
STRIPE_PRICE_DIALER_USD_MONTHLY=

# Resend — workspace invite emails (https://resend.com)
# Create an API key and verify your sending domain (Domains in the Resend dashboard).
RESEND_API_KEY=
# From address must be on your verified domain.
# Private partner offers expect the founder sender below.
RESEND_FROM_EMAIL="Daniel Phillippe <daniel@flyr.software>"
# Optional — where replies go (can be a personal inbox)
# RESEND_REPLY_TO=
