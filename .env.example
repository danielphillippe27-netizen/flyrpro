# Resend — workspace invite emails (https://resend.com)
# Create an API key and verify your sending domain (Domains in the Resend dashboard).
RESEND_API_KEY=
# From address must be on your verified domain, not Gmail. Examples:
#   FLYR <noreply@yourdomain.com>   — invites / system (recommended)
#   FLYR <hello@yourdomain.com>    — general
#   FLYR <support@yourdomain.com>  — support-facing
# Required for invite email to any recipient — not optional once you verify a domain.
RESEND_FROM_EMAIL=
# Optional — where replies go (can be a personal inbox)
# RESEND_REPLY_TO=
