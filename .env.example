# ─────────────────────────────────────────────────────────────
# FLYR PRO — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
#
# For local development you only need the Supabase block.
# Everything else can be left empty — routes that need missing
# vars will fail gracefully or return 500s, but the core app
# will run.
# ─────────────────────────────────────────────────────────────


# ── SUPABASE (required) ───────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Optional direct database connection string for local tooling/scripts.
DATABASE_URL=

# Base URL for QR codes and auth callbacks.
# Use http://localhost:3000 locally, https://flyrpro.app in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-side alias used by some API routes and integrations.
APP_BASE_URL=http://localhost:3000

# Basic Auth credentials for the internal demo link creation tool (/demo/admin)
DEMO_ADMIN_USER=
DEMO_ADMIN_PASSWORD=


# ── STRIPE (required for billing flows) ───────────────────────
# Get these from: Stripe dashboard → Developers → API keys
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=

# Get these from: Stripe dashboard → Products → Price IDs
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# Dialer pricing (regional)
STRIPE_PRICE_DIALER_MONTHLY=
STRIPE_PRICE_DIALER_CAD_MONTHLY=
STRIPE_PRICE_DIALER_USD_MONTHLY=

# Legacy regional price aliases used by older billing routes.
STRIPE_PRICE_CAD_MONTHLY=
STRIPE_PRICE_CAD_YEARLY=
STRIPE_PRICE_USD_MONTHLY=
STRIPE_PRICE_USD_YEARLY=
STRIPE_PRICE_USD_MONTHLY_TEST=
STRIPE_PRICE_USD_YEARLY_TEST=
STRIPE_PRICE_CAD_MONTHLY_TEST=
STRIPE_PRICE_CAD_YEARLY_TEST=
STRIPE_PRICE_USD_MONTHLY_LIVE=
STRIPE_PRICE_USD_YEARLY_LIVE=
STRIPE_PRICE_CAD_MONTHLY_LIVE=
STRIPE_PRICE_CAD_YEARLY_LIVE=

# Optional smoke-test controls for `npm run test:salesperson-payout`.
STRIPE_TEST_CONNECT_ACCOUNT_ID=
SMOKE_PAYOUT_CURRENCY=USD
SMOKE_KEEP_TEST_DATA=0

# Ambassador program coupon IDs
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID=
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID_TEST=
STRIPE_AMBASSADOR_PROMOTION_COUPON_ID_LIVE=


# ── APPLE IAP (required for iOS billing verification) ─────────
# Get these from: App Store Connect → Users and Access → Keys
APPLE_APP_STORE_SERVER_ISSUER_ID=
APPLE_APP_STORE_SERVER_KEY_ID=
APPLE_BUNDLE_ID=com.danielphillippe.FLYR
APPLE_APP_STORE_SERVER_PRIVATE_KEY=
# Set to 'sandbox' for development, 'production' for live
APPLE_ENVIRONMENT=sandbox

# App Store Connect API aliases used by server-side verification/jobs.
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_PRIVATE_KEY=


# ── MAPBOX (required for map views) ──────────────────────────
# Get from: mapbox.com → Account → Access tokens
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Legacy alias still used by some map components.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Default Mapbox style URL used by public/live maps.
NEXT_PUBLIC_MAPBOX_STYLE_ID=
# FLYR standard map style URLs used by the campaign map style resolver.
NEXT_PUBLIC_MAPBOX_STYLE_ID_STANDARD_LIGHT=
NEXT_PUBLIC_MAPBOX_STYLE_ID_STANDARD_DARK=
# Legacy Mapbox v11 style URLs used when the campaign map resolver requests v11.
NEXT_PUBLIC_MAPBOX_STYLE_ID_LEGACY_LIGHT=
NEXT_PUBLIC_MAPBOX_STYLE_ID_LEGACY_DARK=
# Stripped-back map style URLs used by the White Out and Black Out presets.
# White Out defaults to the same iOS light map style when left blank.
NEXT_PUBLIC_MAPBOX_STYLE_ID_WHITEOUT=
NEXT_PUBLIC_MAPBOX_STYLE_ID_BLACKOUT=


# ── GOOGLE MAPS (required for standard canvassing mode) ───────
# Get from: console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_STANDARD_MODE_API_KEY=
# Server-only Places API key for founder/admin prospect discovery and scraper.
# Enable Places API (New) for this key. If you depend on the legacy fallback,
# also allow Places API. Keep this key off the client; do not use a browser-only
# Maps JavaScript key here.
GOOGLE_PLACES_API_KEY=


# ── ROUTING / TILE PROVIDERS (optional map helpers) ──────────
STADIA_API_KEY=
VALHALLA_BASE_URL=
VALHALLA_API_KEY=


# ── TWILIO (required for voice dialer feature) ────────────────
# Get from: console.twilio.com → Account → API keys
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_FROM_NUMBER=
# Optional: SMS follow-up after calls
TWILIO_DEFAULT_SMS_FROM_NUMBER=
# Optional: public HTTPS base URL for Twilio callbacks while running locally
TWILIO_WEBHOOK_BASE_URL=
# Optional: forward inbound calls to this number
TWILIO_INBOUND_FORWARD_TO=
# Optional: spoken message when inbound forwarding is not configured
TWILIO_INBOUND_FALLBACK_MESSAGE=
# Optional: prerecorded voicemail drop audio URL (mp3/wav)
TWILIO_VOICEMAIL_DROP_AUDIO_URL=
# Optional: spoken fallback when voicemail drop audio is not configured
TWILIO_VOICEMAIL_DROP_MESSAGE=
# Optional: comma-separated workspace IDs allowed to use the dialer
DIALER_ENABLED_WORKSPACE_IDS=
# Optional: comma-separated founder emails that bypass dialer test/add-on gating
DIALER_FOUNDER_BYPASS_EMAILS=danielfounder@gmail.com


# ── DIALER VIDEO LANDING (/demo-1 and /power-dialer) ─────────
# Preferred playback source for the public demo page.
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=
NEXT_PUBLIC_DIALER_STREAM_VIDEO_UID=
NEXT_PUBLIC_DIALER_STREAM_POSTER_URL=
# Optional direct MP4/WebM/MOV fallback for local testing only. Cloudflare wins when both are set.
NEXT_PUBLIC_DIALER_VIDEO_URL=
NEXT_PUBLIC_DIALER_VIDEO_CTA_AT_SECONDS=85
# Booking URL for the post-demo founder call CTA.
NEXT_PUBLIC_FOUNDER_CALL_URL=https://calendly.com/daniel-phillippe
# Server-side credentials for scripts/cloudflare-stream-copy-from-s3.ts only.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=


# ── AWS / S3 (required for geodata pipeline) ─────────────────
# Get from: AWS Console → IAM → Access keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
# Legacy bucket alias used by older pipeline scripts/routes.
S3_BUCKET=


# ── DIAMOND GEOMETRY (optional for PMTiles map artifacts) ────
# Local/self-hosted default. Production should point at a worker
# with tippecanoe installed, or at /api/internal/diamond-build on
# an environment that can safely run the builder command.
# Queues Diamond/Bedrock PMTiles overlay builds; required to see map overlays locally.
DIAMOND_BUILD_WEBHOOK_URL=http://localhost:3000/api/internal/diamond-build
# Recommended in production. Generate with: openssl rand -hex 32
DIAMOND_BUILD_WEBHOOK_SECRET=
DIAMOND_BUILD_WEBHOOK_TIMEOUT_MS=5000
# Optional command override. Default is: npm run diamond:build --
DIAMOND_BUILD_COMMAND=
DIAMOND_GEOMETRY_BUCKET=
CLOUDFRONT_GEOMETRY_BASE_URL=https://d34c49t0gfk0ai.cloudfront.net
# Set true only after CloudFront/S3 returns Access-Control-Allow-Origin for PMTiles requests.
DIRECT_PMTILES_CDN_ENABLED=false
# Expanded bbox retry distance in meters when the initial PMTiles building scan returns no results.
PMTILES_EXPANDED_BBOX_RETRY_METERS=75
TIPPECANOE_BIN=tippecanoe

# Optional Lambda-based tile/build hooks used by Diamond/Bedrock pipelines.
SLICE_LAMBDA_URL=
SLICE_SHARED_SECRET=
CVRP_LAMBDA_URL=
CVRP_LAMBDA_SECRET=


# ── RESEND (required for invite and partner offer emails) ─────
# Get from: resend.com → API Keys
# Default sender: Daniel Phillippe <daniel@flyr.software>
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
# Required to verify Resend webhook requests for inbound email.
RESEND_WEBHOOK_SECRET=
# Optional: receiving domain used to route inbound email handles. Defaults to flyr.software.
RESEND_INBOUND_DOMAIN=flyr.software

# ── VERCEL CRON ─────────────────────────────────────────────
# Required in production for scheduled report emails.
CRON_SECRET=


# ── CRM INTEGRATIONS ─────────────────────────────────────────
# Only required if the relevant CRM integration is in use.

# Follow Up Boss — get from: followupboss.com → Admin → API
FOLLOWUPBOSS_CLIENT_ID=
FOLLOWUPBOSS_CLIENT_SECRET=
# OAuth aliases used by the current CRM routes.
FUB_OAUTH_CLIENT_ID=
FUB_OAUTH_CLIENT_SECRET=

# HubSpot — get from: app.hubspot.com → Settings → Integrations → Private Apps
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_APP_ID=
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=

# monday.com — get from: monday.com → Developers → My Apps
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_APP_ID=
MONDAY_APP_SLUG=
MONDAY_SIGNING_SECRET=

# Contractor/home-service CRMs. API base URLs are optional and only needed if a vendor changes endpoints.
JOBNIMBUS_API_BASE=
COMPANYCAM_API_BASE=
COMPANYCAM_OAUTH_CLIENT_ID=
COMPANYCAM_OAUTH_CLIENT_SECRET=
COMPANYCAM_OAUTH_SCOPE=
JOBBER_API_BASE=
JOBBER_OAUTH_CLIENT_ID=
JOBBER_OAUTH_CLIENT_SECRET=
JOBBER_OAUTH_SCOPE=
ACCULYNX_API_BASE=
SUMOQUOTE_API_BASE=
SUMOQUOTE_OAUTH_CLIENT_ID=
SUMOQUOTE_OAUTH_CLIENT_SECRET=
SUMOQUOTE_OAUTH_SCOPE=
SUMOQUOTE_OAUTH_AUDIENCE=
ROOFLINK_API_BASE=

# Random secret string used to sign OAuth state params.
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Random secret string used to encrypt stored CRM credentials.
# Generate with: openssl rand -hex 32
CRM_ENCRYPTION_KEY=


# ── AI / IMAGE GENERATION ────────────────────────────────────
# Only required for flyer generation features.

# Google Gemini — get from: aistudio.google.com → API keys
GOOGLE_GEMINI_API_KEY=
# Legacy Gemini alias used by older generator routes.
GEMINI_API_KEY=

# Replicate — get from: replicate.com → API tokens
REPLICATE_API_TOKEN=

# Optional image generation/removal providers.
FREEPIK=
BG_Remover=


# ── LIVEKIT (optional realtime voice/video features) ─────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=


# ── MOTHERDUCK / DUCKDB ───────────────────────────────────────
# Required for the address/building data pipeline.
# Not needed for local web development.
# Get from: app.motherduck.com → Settings → Tokens
MOTHERDUCK_TOKEN=


# ── EDITOR ───────────────────────────────────────────────────
# URL of the separately deployed Canva-clone editor.
# Leave empty if running the editor routes locally.
NEXT_PUBLIC_EDITOR_URL=


# ── VERCEL (normally injected by Vercel in production) ────────
# Only set locally when testing Vercel OIDC-dependent integrations.
VERCEL_OIDC_TOKEN=
